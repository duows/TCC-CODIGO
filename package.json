{
  "name": "hardware-csp",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema Especialista Educacional para Validação de Compatibilidade de Hardware baseado em CSP",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @hardware-csp/api prisma:migrate",
    "db:seed": "pnpm --filter @hardware-csp/api prisma:seed",
    "db:studio": "pnpm --filter @hardware-csp/api prisma:studio",
    "db:reset": "pnpm --filter @hardware-csp/api prisma:reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.4.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
